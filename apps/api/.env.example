# ─── Database (Neon Postgres) ──────────────────────────────────────────────────
# Pooled connection URL — used by Prisma at runtime
DATABASE_URL="postgresql://user:password@host/livedoc?sslmode=require&pgbouncer=true"
# Direct (non-pooled) connection URL — required for Prisma migrations on Neon
DIRECT_URL="postgresql://user:password@host/livedoc?sslmode=require"

# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
REDIS_URL="redis://default:password@host:6379"

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── Notion OAuth ─────────────────────────────────────────────────────────────
NOTION_CLIENT_ID="your-notion-client-id"
NOTION_CLIENT_SECRET="your-notion-client-secret"
NOTION_REDIRECT_URI="http://localhost:3001/api/sources/notion/callback"

# ─── Google OAuth (for Better Auth) ──────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Better Auth ──────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3001"

# ─── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="LiveDoc <noreply@yourdomain.com>"

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"
PORT="3001"
NODE_ENV="development"

# ─── Encryption ───────────────────────────────────────────────────────────────
# AES-256 key for encrypting OAuth tokens at rest — must be exactly 32 bytes (64 hex chars)
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY="your-64-char-hex-string-here"
