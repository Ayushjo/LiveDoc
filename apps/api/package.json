    "better-auth": "^1.2.7",
    "bullmq": "^5.21.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "ioredis": "^5.4.1",
    "openai": "^4.96.0",
    "resend": "^4.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.30",
    "prisma": "^6.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.4.5"
  }
